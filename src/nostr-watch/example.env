# === Nostr Identity (ecosystem standard) ===
# Required: Keep these secret! DO NOT COMMIT THIS FILE.

# Your Nostr secret key (nsec format)
# Anyone with this key can act as your Nostr identity
NOSTR_SECRET_KEY=nsec1yoursecretkeyhere

# Your Nostr public key (npub or hex format)
# This is what nostr-watch uses to filter events
NOSTR_PUBLIC_KEY=npub1_or_hex_your_public_key_here

# === Nostr Configuration (ecosystem standard) ===
# Optional: Used by multiple Nostr tools (nak, bray, etc.)

# Space-separated list of relay WebSocket URLs
# Default: wss://relay.damus.io wss://nos.lol wss://relay.snort.social
NOSTR_RELAYS=wss://relay.damus.io wss://nos.lol wss://relay.snort.social

# === nostr-watch Configuration (tool-specific) ===
# Optional: Override devcontainer feature defaults

# Event kinds to monitor (space-separated)
# 1059 = NIP-17 gift-wrapped DMs (default)
NOSTR_WATCH_KINDS=1059

# Comma-separated list of allowed sender pubkeys (hex format)
# Leave empty for NIP-17 encrypted messages (wrapper keys hide real sender)
NOSTR_WATCH_ALLOWED_SENDERS=

# State directory for watcher files (handoffs, seen markers, logs)
# Default: .nostr-watch
NOSTR_WATCH_STATE_DIR=/workspace/.nostr-watch

# Log file path
# Default: $NOSTR_WATCH_STATE_DIR/watcher.log
NOSTR_WATCH_LOG_FILE=/workspace/.data/nostr-watch/watcher.log

# Maximum log file size in bytes before reset
# Default: 1048576 (1MB)
NOSTR_WATCH_LOG_MAX_SIZE=1048576

# Start mode: foreground or daemon
# Default: daemon
NOSTR_WATCH_START_MODE=daemon

# Reconnect delay in seconds after errors
# Default: 5
NOSTR_WATCH_RECONNECT_SECONDS=5

# Days to retain handoff files (set -1 to disable)
# Default: 7
NOSTR_WATCH_HANDOFF_RETENTION_DAYS=7

# Days to retain seen marker files (set -1 to disable)
# Default: 7
NOSTR_WATCH_SEEN_RETENTION_DAYS=7

# Cleanup interval in seconds
# Default: 3600 (1 hour)
NOSTR_WATCH_CLEANUP_INTERVAL=3600

# Maximum files per directory before emergency cleanup (set -1 to disable)
# Default: 1000
NOSTR_WATCH_MAX_FILES_PER_DIR=1000

# Agent command to execute when events arrive
# Receives handoff file path as first argument ($1)
# Default: cat (just displays the file)
# Examples:
#   - cat (display only)
#   - /workspace/scripts/process-event.sh (custom script)
#   - github-copilot-agent (if integrated with Copilot)
NOSTR_WATCH_AGENT_CMD=cat

# === Task Spooler Configuration ===
# Optional: Advanced task queue configuration

# Task spooler socket path (leave default for most cases)
# TS_SOCKET=/workspace/.data/nostr-watch/task-spooler.sock

# Maximum finished tasks to keep in queue
# TS_MAXFINISHED=100
